generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  CLIENT      // Was: PARTNER - Creates tasks (external customer)
  DISPATCHER  // Was: OFFICE - Assigns workers, monitors operations
  TECHNICIAN  // Was: WORKER - Executes tasks in the field
}

// Access level for organization delegation
enum AccessLevel {
  NONE           // No access - manager sees nothing
  TASKS_ONLY     // Can view tasks only
  TASKS_ASSIGN   // Can view tasks + assign workers
  FULL           // Can view everything + assign
}

enum TaskStatus {
  DRAFT
  NEW
  ASSIGNED
  ACCEPTED     // Technician acknowledges the assigned task
  EN_ROUTE     // Technician is traveling to the job location
  ARRIVED      // Technician has arrived at the location
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELED
  CLOSED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskEventType {
  CREATED
  UPDATED
  ASSIGNED
  UNASSIGNED
  STATUS_CHANGED
  COMMENT_ADDED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
}

enum AttachmentType {
  IMAGE
  DOCUMENT
  OTHER
}

// Models
model Organization {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
  tasks Task[]

  // Organization delegation relationships
  grantedAccess  OrganizationAccess[] @relation("Grantor")  // Access this org has granted to others
  receivedAccess OrganizationAccess[] @relation("Grantee")  // Access this org has received from others

  @@map("organizations")
}

// Many-to-many delegation: Org A can manage Org B (if B grants access)
model OrganizationAccess {
  id String @id @default(cuid())

  // Who is granting access (the managed org)
  grantorOrgId String
  grantorOrg   Organization @relation("Grantor", fields: [grantorOrgId], references: [id], onDelete: Cascade)

  // Who is receiving access (the manager org)
  granteeOrgId String
  granteeOrg   Organization @relation("Grantee", fields: [granteeOrgId], references: [id], onDelete: Cascade)

  // Access level
  accessLevel AccessLevel @default(NONE)

  // Granular permissions (for fine-tuned control)
  canViewTasks     Boolean @default(false)
  canAssignWorkers Boolean @default(false)
  canViewWorkers   Boolean @default(false)
  canViewTracking  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Each org pair can only have one access record
  @@unique([grantorOrgId, granteeOrgId])
  @@index([grantorOrgId])
  @@index([granteeOrgId])
  @@map("organization_access")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           Role
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Security: Account lockout fields
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdTasks   Task[]       @relation("TaskCreator")
  assignedTasks  Task[]       @relation("TaskAssignee")
  comments       Comment[]
  attachments    Attachment[]
  taskEvents     TaskEvent[]
  lastLocation         WorkerLastLocation?
  locationHistory      LocationHistory[]
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]

  @@index([organizationId])
  @@index([role])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique  // Store SHA-256 hash, not plain token
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Grace period fields for handling concurrent refresh requests
  usedAt               DateTime?  // When the token was first used (null = not used yet)
  replacedByTokenHash  String?    // Hash of the new token that replaced this one
  cachedAccessToken    String?    // Cached access token to return during grace period
  cachedRefreshToken   String?    // Cached refresh token to return during grace period (temporary, deleted after grace period)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([usedAt])  // For cleanup of old used tokens
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique  // Store SHA-256 hash, not plain token
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(NEW)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?

  locationLat     Float?
  locationLng     Float?
  locationAddress String?

  // Route tracking fields
  routeStartedAt DateTime?  // When EN_ROUTE started
  routeEndedAt   DateTime?  // When ARRIVED
  routeDistance  Float?     // Total distance in meters

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdById String
  createdBy   User   @relation("TaskCreator", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("TaskAssignee", fields: [assignedToId], references: [id])

  comments        Comment[]
  attachments     Attachment[]
  events          TaskEvent[]
  locationHistory LocationHistory[]

  @@index([organizationId])
  @@index([status])
  @@index([createdById])
  @@index([assignedToId])
  @@index([createdAt])
  @@map("tasks")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
  @@map("comments")
}

model Attachment {
  id        String         @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  AttachmentType
  fileSize  Int
  createdAt DateTime       @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  @@index([taskId])
  @@map("attachments")
}

model TaskEvent {
  id        String        @id @default(cuid())
  eventType TaskEventType
  metadata  Json?
  createdAt DateTime      @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([eventType])
  @@index([createdAt])
  @@map("task_events")
}

model WorkerLastLocation {
  id        String   @id @default(cuid())
  lat       Float
  lng       Float
  accuracy  Float?
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("worker_last_locations")
}

// Location history for route tracking during EN_ROUTE status
model LocationHistory {
  id        String   @id @default(cuid())
  lat       Float
  lng       Float
  accuracy  Float?
  timestamp DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId String?
  task   Task?  @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, timestamp])
  @@index([taskId, timestamp])
  @@map("location_history")
}
