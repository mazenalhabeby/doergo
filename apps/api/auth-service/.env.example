# Database
DATABASE_URL="postgresql://doergo:doergo_secret@localhost:5432/doergo?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# ==============================================================================
# JWT Configuration - SECURITY CRITICAL
# ==============================================================================
# IMPORTANT: Generate strong, unique secrets for production!
# - Minimum 32 characters (64+ recommended)
# - Use cryptographically secure random values
# - Use DIFFERENT secrets for access and refresh tokens
# - NEVER use default values in production
# - NEVER commit real secrets to version control
#
# Generate secure secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   openssl rand -hex 64
# ==============================================================================
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_NEVER_USE_THIS_DEFAULT_1
JWT_REFRESH_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_NEVER_USE_THIS_DEFAULT_2
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=24h
JWT_REFRESH_EXPIRATION_REMEMBER=30d
