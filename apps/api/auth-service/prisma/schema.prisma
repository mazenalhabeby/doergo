generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums
enum Role {
  ADMIN       // Organization owner/admin - full control
  CLIENT      // DEPRECATED: Use ADMIN instead (kept for backward compatibility)
  DISPATCHER  // Office manager - assigns workers, monitors operations
  TECHNICIAN  // Field worker - executes tasks
}

// Platform access restriction
enum Platform {
  WEB     // Web app only
  MOBILE  // Mobile app only
  BOTH    // Both platforms
}

// Access level for organization delegation
enum AccessLevel {
  NONE           // No access - manager sees nothing
  TASKS_ONLY     // Can view tasks only
  TASKS_ASSIGN   // Can view tasks + assign workers
  FULL           // Can view everything + assign
}

enum TaskStatus {
  DRAFT
  NEW
  ASSIGNED
  ACCEPTED     // Technician acknowledges the assigned task
  EN_ROUTE     // Technician is traveling to the job location
  ARRIVED      // Technician has arrived at the location
  IN_PROGRESS
  BLOCKED
  COMPLETED
  CANCELED
  CLOSED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskEventType {
  CREATED
  UPDATED
  ASSIGNED
  UNASSIGNED
  STATUS_CHANGED
  COMMENT_ADDED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
}

enum AttachmentType {
  IMAGE
  DOCUMENT
  OTHER
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
}

enum ReportAttachmentType {
  BEFORE  // Photo taken before work started
  AFTER   // Photo taken after work completed
}

// Technician employment/billing type (who pays for expenses)
enum TechnicianType {
  FREELANCER  // Covers own trips and expenses
  FULL_TIME   // Company covers trips and expenses
}

// Where the technician works (decoupled from billing type)
enum WorkMode {
  ON_SITE  // Works at company locations (attendance tracking)
  ON_ROAD  // Works on-the-go (task-based, no attendance)
  HYBRID   // Both on-site and on-road
}

// Time entry status for attendance tracking
enum TimeEntryStatus {
  CLOCKED_IN   // Currently clocked in
  CLOCKED_OUT  // Normal clock out
  AUTO_OUT     // System auto clock-out (midnight, etc.)
}

// Time entry approval status
enum ApprovalStatus {
  PENDING    // Awaiting manager review
  APPROVED   // Manager approved
  REJECTED   // Manager rejected
  AUTO       // Auto-approved (e.g., within geofence, normal hours)
}

// Break type for attendance tracking
enum BreakType {
  LUNCH    // Lunch break (typically 30-60 min)
  SHORT    // Short break (typically 10-15 min)
  OTHER    // Other break type
}

// Time-off request status
enum TimeOffStatus {
  PENDING    // Awaiting manager approval
  APPROVED   // Manager approved
  REJECTED   // Manager rejected
  CANCELED   // Technician canceled the request
}

// Invitation status
enum InvitationStatus {
  PENDING    // Created, waiting to be used
  ACCEPTED   // Used by a new user
  EXPIRED    // Past expiry date
  REVOKED    // Manually canceled by creator/admin
}

// Organization join policy
enum JoinPolicy {
  OPEN          // Anyone with org code can request to join
  INVITE_ONLY   // Only via one-time invitation codes
  CLOSED        // No new members
}

// Join request status
enum JoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

// ==================== MONITORING ENUMS ====================

// Monitoring event types for activity logging
enum MonitoringEventType {
  USER_LOGIN
  USER_LOGOUT
  USER_LOGIN_FAILED
  USER_CREATED
  USER_UPDATED
  USER_DELETED
  TASK_CREATED
  TASK_ASSIGNED
  TASK_UNASSIGNED
  TASK_STATUS_CHANGED
  TASK_COMPLETED
  TASK_DELETED
  NOTIFICATION_SENT
  NOTIFICATION_FAILED
  CLOCK_IN
  CLOCK_OUT
  GEOFENCE_VIOLATION
  TECHNICIAN_OFFLINE
  TASK_OVERDUE
  API_ERROR
  SERVICE_DOWN
  SERVICE_UP
}

// Alert severity levels
enum AlertSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

// Alert status
enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
  DISMISSED
}

// Notification delivery channel
enum NotificationChannel {
  EMAIL
  PUSH
  SMS
  SOCKET
}

// Notification delivery status
enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  BOUNCED
}

// Models
model Organization {
  id        String   @id @default(cuid())
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Join system
  joinCodeHash String?     @unique  // SHA-256 hash of persistent org join code
  joinPolicy   JoinPolicy  @default(INVITE_ONLY)

  users User[]
  tasks Task[]

  // Organization delegation relationships
  grantedAccess  OrganizationAccess[] @relation("Grantor")  // Access this org has granted to others
  receivedAccess OrganizationAccess[] @relation("Grantee")  // Access this org has received from others

  // Asset management
  assetCategories AssetCategory[]
  assets          Asset[]

  // Service reports
  serviceReports ServiceReport[]

  // Company locations for full-time technician attendance
  companyLocations CompanyLocation[]

  // Time entries for attendance tracking
  timeEntries TimeEntry[]

  // Invitations
  invitations Invitation[]

  // Join requests
  joinRequests JoinRequest[]

  // Monitoring
  activityLogs          ActivityLog[]
  notificationDeliveries NotificationDelivery[]
  alerts                Alert[]
  dailyMetrics          DailyMetric[]

  @@map("organizations")
}

// Many-to-many delegation: Org A can manage Org B (if B grants access)
model OrganizationAccess {
  id String @id @default(cuid())

  // Who is granting access (the managed org)
  grantorOrgId String
  grantorOrg   Organization @relation("Grantor", fields: [grantorOrgId], references: [id], onDelete: Cascade)

  // Who is receiving access (the manager org)
  granteeOrgId String
  granteeOrg   Organization @relation("Grantee", fields: [granteeOrgId], references: [id], onDelete: Cascade)

  // Access level
  accessLevel AccessLevel @default(NONE)

  // Granular permissions (for fine-tuned control)
  canViewTasks     Boolean @default(false)
  canAssignWorkers Boolean @default(false)
  canViewWorkers   Boolean @default(false)
  canViewTracking  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Each org pair can only have one access record
  @@unique([grantorOrgId, granteeOrgId])
  @@index([grantorOrgId])
  @@index([granteeOrgId])
  @@map("organization_access")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  firstName      String
  lastName       String
  role           Role
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Security: Account lockout fields
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?

  // Permission fields (granular access control)
  platform        Platform @default(BOTH)    // Which platforms user can access
  canCreateTasks  Boolean  @default(false)   // Can create new tasks
  canViewAllTasks Boolean  @default(false)   // Can view all org tasks (vs only assigned/created)
  canAssignTasks  Boolean  @default(false)   // Can assign tasks to technicians
  canManageUsers  Boolean  @default(false)   // Can manage users in organization

  // Technician-specific fields (only used when role = TECHNICIAN)
  technicianType TechnicianType @default(FREELANCER)  // Billing: who pays for expenses
  workMode       WorkMode       @default(HYBRID)      // Where they work: on-site, on-road, or both
  specialty      String?   // e.g., "Electrical", "Plumbing", "Mechanical", "General"
  rating         Float?    @default(5.0) // Average rating (1-5)
  ratingCount    Int?      @default(0)   // Number of ratings received
  maxDailyJobs   Int?      @default(5)   // Maximum jobs per day

  // Onboarding flag (false = orphan user needs to complete onboarding wizard)
  onboardingCompleted Boolean @default(true)

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])

  createdTasks   Task[]       @relation("TaskCreator")
  assignedTasks  Task[]       @relation("TaskAssignee")
  comments       Comment[]
  attachments    Attachment[]
  taskEvents     TaskEvent[]
  lastLocation         WorkerLastLocation?
  locationHistory      LocationHistory[]
  refreshTokens        RefreshToken[]
  passwordResetTokens  PasswordResetToken[]
  serviceReports       ServiceReport[]
  assignments          TechnicianAssignment[]  // Technician location assignments
  timeEntries          TimeEntry[]             // Clock-in/clock-out records
  approvedTimeEntries  TimeEntry[]  @relation("ApprovedTimeEntries")  // Time entries approved by this user
  editedTimeEntries    TimeEntry[]  @relation("EditedTimeEntries")    // Time entries edited by this user

  // Monitoring
  activityLogs         ActivityLog[] @relation("ActivityLogUser")     // Activity performed by this user
  targetedActivityLogs ActivityLog[] @relation("ActivityLogTarget")   // Activity targeting this user
  notificationDeliveries NotificationDelivery[]                       // Notifications sent to this user
  alerts               Alert[]                                        // Alerts related to this user

  // Push notifications
  pushTokens           UserPushToken[]                                // Device push tokens for notifications

  // Availability management
  schedules            TechnicianSchedule[]                           // Weekly recurring schedule
  timeOffRequests      TimeOff[]             @relation("TechnicianTimeOff")   // Time-off requests submitted
  approvedTimeOffs     TimeOff[]             @relation("TimeOffApprover")     // Time-off requests approved by this user

  // Invitations
  createdInvitations   Invitation[]          @relation("InvitationCreator")   // Invitations created by this user

  // Join requests
  joinRequests         JoinRequest[]         @relation("UserJoinRequests")    // Join requests submitted by this user
  reviewedJoinRequests JoinRequest[]         @relation("JoinRequestReviewer") // Join requests reviewed by this user

  @@index([organizationId])
  @@index([role])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique  // Store SHA-256 hash, not plain token
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Grace period fields for handling concurrent refresh requests
  usedAt               DateTime?  // When the token was first used (null = not used yet)
  replacedByTokenHash  String?    // Hash of the new token that replaced this one
  cachedAccessToken    String?    // Cached access token to return during grace period
  cachedRefreshToken   String?    // Cached refresh token to return during grace period (temporary, deleted after grace period)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([usedAt])  // For cleanup of old used tokens
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique  // Store SHA-256 hash, not plain token
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

// Push notification tokens for mobile devices
model UserPushToken {
  id        String   @id @default(cuid())
  token     String   @unique  // Expo push token (e.g., ExponentPushToken[xxx])
  platform  String             // 'ios' | 'android' | 'web'
  deviceId  String?            // Optional device identifier for deduplication
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("user_push_tokens")
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TaskStatus   @default(NEW)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?

  locationLat     Float?
  locationLng     Float?
  locationAddress String?

  // Route tracking fields
  routeStartedAt DateTime?  // When EN_ROUTE started
  routeEndedAt   DateTime?  // When ARRIVED
  routeDistance  Float?     // Total distance in meters

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  createdById String
  createdBy   User   @relation("TaskCreator", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("TaskAssignee", fields: [assignedToId], references: [id])

  // Optional link to asset for maintenance history
  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  comments        Comment[]
  attachments     Attachment[]
  events          TaskEvent[]
  locationHistory LocationHistory[]
  serviceReport   ServiceReport?

  @@index([organizationId])
  @@index([status])
  @@index([createdById])
  @@index([assignedToId])
  @@index([assetId])
  @@index([createdAt])
  @@map("tasks")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
  @@map("comments")
}

model Attachment {
  id        String         @id @default(cuid())
  fileName  String
  fileUrl   String
  fileType  AttachmentType
  fileSize  Int
  createdAt DateTime       @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  @@index([taskId])
  @@map("attachments")
}

model TaskEvent {
  id        String        @id @default(cuid())
  eventType TaskEventType
  metadata  Json?
  createdAt DateTime      @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([taskId])
  @@index([eventType])
  @@index([createdAt])
  @@map("task_events")
}

model WorkerLastLocation {
  id        String   @id @default(cuid())
  lat       Float
  lng       Float
  accuracy  Float?
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("worker_last_locations")
}

// Location history for route tracking during EN_ROUTE status
model LocationHistory {
  id        String   @id @default(cuid())
  lat       Float
  lng       Float
  accuracy  Float?
  timestamp DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  taskId String?
  task   Task?  @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([userId, timestamp])
  @@index([taskId, timestamp])
  @@map("location_history")
}

// Dynamic category created by organization (e.g., "HVAC", "Electrical", "Plumbing")
model AssetCategory {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  color       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  types  AssetType[]
  assets Asset[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("asset_categories")
}

// Dynamic type within a category (e.g., under HVAC: "Air Conditioner", "Heater")
model AssetType {
  id          String   @id @default(cuid())
  name        String
  description String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryId String
  category   AssetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  assets Asset[]

  @@unique([categoryId, name])
  @@index([categoryId])
  @@map("asset_types")
}

// The actual equipment/asset
model Asset {
  id           String      @id @default(cuid())
  name         String
  serialNumber String?
  model        String?
  manufacturer String?

  status AssetStatus @default(ACTIVE)

  installDate    DateTime?
  warrantyExpiry DateTime?

  locationAddress String?
  locationLat     Float?
  locationLng     Float?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  categoryId String?
  category   AssetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  typeId String?
  type   AssetType? @relation(fields: [typeId], references: [id], onDelete: SetNull)

  // Tasks linked to this asset (maintenance history)
  tasks          Task[]
  serviceReports ServiceReport[]

  @@index([organizationId])
  @@index([categoryId])
  @@index([typeId])
  @@index([status])
  @@index([serialNumber])
  @@map("assets")
}

// Service report created when technician completes a task
model ServiceReport {
  id String @id @default(cuid())

  // Link to task (one-to-one)
  taskId String @unique
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  // Link to asset (denormalized for faster history queries)
  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  // Work details
  summary       String  // Brief summary of work done
  workPerformed String? // Detailed description
  workDuration  Int     // Duration in seconds (from mobile timer)

  // Signatures (base64 encoded PNG or URL)
  technicianSignature String? @db.Text
  customerSignature   String? @db.Text
  customerName        String? // Who signed

  // Metadata
  completedAt   DateTime
  completedById String
  completedBy   User     @relation(fields: [completedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  attachments ReportAttachment[]
  partsUsed   PartUsed[]

  // Organization scope (for multi-tenant queries)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([taskId])
  @@index([assetId])
  @@index([completedAt])
  @@index([organizationId])
  @@map("service_reports")
}

// Attachment for service report (before/after photos)
model ReportAttachment {
  id String @id @default(cuid())

  reportId String
  report   ServiceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  type     ReportAttachmentType // BEFORE or AFTER
  fileName String
  fileUrl  String
  fileSize Int                  // bytes
  caption  String?              // Optional description

  createdAt DateTime @default(now())

  @@index([reportId])
  @@map("report_attachments")
}

// Parts/materials used in service
model PartUsed {
  id String @id @default(cuid())

  reportId String
  report   ServiceReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  name       String  // "Air Filter", "Compressor Belt"
  partNumber String? // Optional SKU/part number
  quantity   Int     @default(1)
  unitCost   Float?  // Optional cost per unit
  notes      String?

  createdAt DateTime @default(now())

  @@index([reportId])
  @@map("parts_used")
}

// Company location for full-time technician attendance (clock in/out)
model CompanyLocation {
  id             String  @id @default(cuid())
  name           String  // "Main Office", "Warehouse A"
  address        String? // Full address string
  lat            Float   // Latitude
  lng            Float   // Longitude
  geofenceRadius Int     @default(15) // Radius in meters for clock-in zone
  isActive       Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Technicians assigned to this location
  assignments TechnicianAssignment[]

  // Time entries at this location
  timeEntries TimeEntry[]

  @@index([organizationId])
  @@index([isActive])
  @@map("company_locations")
}

// Technician assignment to company location (many-to-many)
model TechnicianAssignment {
  id String @id @default(cuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  locationId String
  location   CompanyLocation @relation(fields: [locationId], references: [id], onDelete: Cascade)

  isPrimary Boolean  @default(false) // Main work location
  schedule  String[] @default([])    // Work days: ["MON", "TUE", "WED", "THU", "FRI"]

  effectiveFrom DateTime  @default(now()) // Assignment start date
  effectiveTo   DateTime?                 // Assignment end date (null = indefinite)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, locationId]) // One assignment per user-location pair
  @@index([userId])
  @@index([locationId])
  @@map("technician_assignments")
}

// Time entry for attendance tracking (clock-in/clock-out records)
model TimeEntry {
  id String @id @default(cuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  locationId String
  location   CompanyLocation @relation(fields: [locationId], references: [id])

  status TimeEntryStatus @default(CLOCKED_IN)

  // Clock in data
  clockInAt       DateTime @default(now())
  clockInLat      Float
  clockInLng      Float
  clockInAccuracy Float?

  // Clock out data (null until clocked out)
  clockOutAt       DateTime?
  clockOutLat      Float?
  clockOutLng      Float?
  clockOutAccuracy Float?

  // Geofence validation results
  clockInWithinGeofence  Boolean  @default(true)
  clockOutWithinGeofence Boolean?

  // Calculated duration (set on clock-out)
  totalMinutes Int?

  // Break duration (calculated from breaks)
  breakMinutes Int @default(0)

  notes String?

  // Approval workflow
  approvalStatus   ApprovalStatus @default(PENDING)
  approvedById     String?
  approvedBy       User?          @relation("ApprovedTimeEntries", fields: [approvedById], references: [id])
  approvedAt       DateTime?
  approvalNotes    String?

  // Edit tracking
  isEdited         Boolean        @default(false)
  editedById       String?
  editedBy         User?          @relation("EditedTimeEntries", fields: [editedById], references: [id])
  editedAt         DateTime?
  originalClockIn  DateTime?      // Original value before edit
  originalClockOut DateTime?      // Original value before edit
  editReason       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  // Breaks taken during this shift
  breaks Break[]

  @@index([userId, clockInAt])
  @@index([locationId])
  @@index([organizationId])
  @@index([status])
  @@index([approvalStatus])
  @@map("time_entries")
}

// Break records for time entries
model Break {
  id String @id @default(cuid())

  timeEntryId String
  timeEntry   TimeEntry @relation(fields: [timeEntryId], references: [id], onDelete: Cascade)

  type BreakType @default(SHORT)

  startedAt DateTime @default(now())
  endedAt   DateTime?

  // Duration in minutes (calculated on end)
  durationMinutes Int?

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([timeEntryId])
  @@index([startedAt])
  @@map("breaks")
}

// ==================== AVAILABILITY & SCHEDULING ====================

// Technician recurring weekly schedule (e.g., "Monday 9:00-17:00")
model TechnicianSchedule {
  id String @id @default(cuid())

  technicianId String
  technician   User @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  dayOfWeek Int      // 0=Sunday, 1=Monday, ..., 6=Saturday
  startTime String   // "09:00" (24h format)
  endTime   String   // "17:00" (24h format)
  isActive  Boolean  @default(true)

  // Optional: schedule can be location-specific
  notes String?      // Optional note (e.g., "Remote day")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Each technician can only have one schedule entry per day
  @@unique([technicianId, dayOfWeek])
  @@index([technicianId])
  @@index([dayOfWeek, isActive])
  @@map("technician_schedules")
}

// Time-off request (vacation, sick day, personal leave)
model TimeOff {
  id String @id @default(cuid())

  technicianId String
  technician   User @relation("TechnicianTimeOff", fields: [technicianId], references: [id], onDelete: Cascade)

  startDate DateTime @db.Date  // First day of time off
  endDate   DateTime @db.Date  // Last day of time off (inclusive)
  reason    String?            // "Vacation", "Sick leave", "Personal", etc.

  status TimeOffStatus @default(PENDING)

  // Approval workflow
  approvedById String?
  approvedBy   User?    @relation("TimeOffApprover", fields: [approvedById], references: [id])
  approvedAt   DateTime?
  rejectionReason String?  // If rejected, reason why

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([technicianId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("time_off_requests")
}

// ==================== INVITATION SYSTEM ====================

// Invitation for users to join an organization with a pre-assigned role
model Invitation {
  id String @id @default(cuid())

  // Short code stored as SHA-256 hash (e.g., "XK7M2P" → hash)
  codeHash String @unique

  // Target role and organization
  targetRole     Role
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Technician-specific fields (only used when targetRole = TECHNICIAN)
  technicianType TechnicianType?
  workMode       WorkMode?
  specialty      String?
  maxDailyJobs   Int?

  // Status tracking
  status    InvitationStatus @default(PENDING)
  expiresAt DateTime
  usedAt    DateTime?

  // Who accepted the invitation (null until accepted)
  acceptedById String?

  // Who created the invitation
  createdById String
  createdBy   User @relation("InvitationCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([createdById])
  @@index([expiresAt])
  @@map("invitations")
}

// ==================== JOIN REQUEST SYSTEM ====================

// Request from an orphan user to join an organization
model JoinRequest {
  id              String             @id @default(cuid())

  userId          String
  user            User               @relation("UserJoinRequests", fields: [userId], references: [id], onDelete: Cascade)

  organizationId  String
  organization    Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  message         String?            // Optional message from the requesting user

  status          JoinRequestStatus  @default(PENDING)

  // Review fields (set when admin approves/rejects)
  reviewedById    String?
  reviewedBy      User?              @relation("JoinRequestReviewer", fields: [reviewedById], references: [id])
  reviewedAt      DateTime?
  rejectionReason String?

  // Role assignment (set by admin on approval)
  assignedRole     Role?
  assignedPlatform Platform?

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@unique([userId, organizationId, status])
  @@index([organizationId, status])
  @@index([userId])
  @@map("join_requests")
}

// ==================== MONITORING MODELS ====================

// Activity log for audit trail
model ActivityLog {
  id              String              @id @default(cuid())
  eventType       MonitoringEventType

  // Who performed the action
  userId          String?
  user            User?               @relation("ActivityLogUser", fields: [userId], references: [id], onDelete: SetNull)

  // Who was affected (e.g., user being assigned, deleted)
  targetUserId    String?
  targetUser      User?               @relation("ActivityLogTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  // Resource context
  resourceType    String?             // "task", "user", "report", "timeEntry", etc.
  resourceId      String?

  // Additional context
  metadata        Json?               // { previousStatus, newStatus, reason, etc. }
  ipAddress       String?
  userAgent       String?

  // Organization scope
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime            @default(now())

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([resourceType, resourceId])
  @@map("activity_logs")
}

// System health metrics (time-series data)
model HealthMetric {
  id              String   @id @default(cuid())
  serviceName     String   // "gateway", "auth-service", "task-service", etc.
  metricType      String   // "latency", "error_rate", "request_count", "memory_usage"
  value           Float
  timestamp       DateTime @default(now())
  metadata        Json?    // { endpoint, statusCode, errorMessage, etc. }

  @@index([serviceName, timestamp])
  @@index([metricType, timestamp])
  @@map("health_metrics")
}

// Notification delivery tracking
model NotificationDelivery {
  id              String              @id @default(cuid())
  channel         NotificationChannel
  status          NotificationStatus  @default(PENDING)

  // Recipient
  recipientId     String
  recipient       User                @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  // Event that triggered the notification
  eventType       String              // "task.assigned", "task.completed", "alert.raised", etc.
  payload         Json?               // The notification content/data

  // Delivery tracking
  sentAt          DateTime?
  deliveredAt     DateTime?
  failureReason   String?
  retryCount      Int                 @default(0)

  // Organization scope
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([organizationId, createdAt])
  @@index([recipientId, createdAt])
  @@index([channel, status])
  @@index([eventType])
  @@map("notification_deliveries")
}

// Real-time alerts
model Alert {
  id              String        @id @default(cuid())
  type            String        // "technician_offline", "task_overdue", "geofence_violation", "high_error_rate"
  severity        AlertSeverity @default(WARNING)
  status          AlertStatus   @default(ACTIVE)

  // Alert content
  title           String
  message         String
  metadata        Json?         // { technicianName, taskId, lastSeen, overdueBy, etc. }

  // Related entities (optional)
  userId          String?       // Related user (e.g., offline technician)
  user            User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  taskId          String?       // Related task

  // Lifecycle tracking
  acknowledgedAt  DateTime?
  acknowledgedById String?
  resolvedAt      DateTime?
  resolvedById    String?

  // Organization scope
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([organizationId, status])
  @@index([severity, status])
  @@index([type, createdAt])
  @@index([userId])
  @@map("alerts")
}

// Daily aggregated metrics for reports (computed nightly)
model DailyMetric {
  id              String   @id @default(cuid())
  date            DateTime @db.Date

  // Organization scope
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Task metrics
  tasksCreated        Int      @default(0)
  tasksCompleted      Int      @default(0)
  tasksCanceled       Int      @default(0)
  tasksOverdue        Int      @default(0)
  avgCompletionTime   Float?   // Average time to complete tasks (in minutes)

  // User metrics
  activeUsers         Int      @default(0)
  loginCount          Int      @default(0)
  failedLoginCount    Int      @default(0)

  // Attendance metrics
  clockInCount        Int      @default(0)
  avgWorkHours        Float?   // Average hours worked
  geofenceViolations  Int      @default(0)

  // Notification metrics
  emailsSent          Int      @default(0)
  emailsFailed        Int      @default(0)
  pushSent            Int      @default(0)
  pushFailed          Int      @default(0)

  // Alert metrics
  alertsRaised        Int      @default(0)
  alertsResolved      Int      @default(0)

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([date, organizationId])
  @@index([organizationId, date])
  @@map("daily_metrics")
}
