# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1

# CORS - allowed origins (add mobile device IPs for development)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Redis (for microservices communication)
REDIS_HOST=localhost
REDIS_PORT=6379

# ==============================================================================
# JWT Configuration - SECURITY CRITICAL
# ==============================================================================
# IMPORTANT: Generate strong, unique secrets for production!
# - Minimum 32 characters (64+ recommended)
# - Use cryptographically secure random values
# - NEVER use default values in production
# - NEVER commit real secrets to version control
#
# Generate a secure secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#   openssl rand -hex 64
# ==============================================================================
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING_NEVER_USE_THIS_DEFAULT
